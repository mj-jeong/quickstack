{
	"name": "quick-stack-tool",
	"version": "0.1.0",
	"description": "Next.js project setup CLI with preset-based scaffolding and library integration",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mj-jeong/quickstack.git"
	},
	"homepage": "https://github.com/mj-jeong/quickstack#readme",
	"bugs": {
		"url": "https://github.com/mj-jeong/quickstack/issues"
	},
	"keywords": [
		"nextjs",
		"cli",
		"scaffold",
		"preset",
		"tailwind",
		"shadcn",
		"prisma",
		"drizzle",
		"nextauth",
		"supabase",
		"quickstack",
		"create-next-app",
		"boilerplate"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"quickstack": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/cli/index.d.ts",
			"import": "./dist/cli/index.js"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "tsx src/cli/index.ts",
		"build": "tsdown",
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:e2e": "vitest run --project e2e",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --project unit --project integration --coverage",
		"prepublishOnly": "pnpm build && pnpm dlx publint",
		"fixtures:refresh": "tsx scripts/refresh-fixtures.ts"
	},
	"dependencies": {
		"@inquirer/prompts": "^7.0.0",
		"commander": "^13.0.0",
		"ora": "^8.0.0",
		"picocolors": "^1.1.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^3.1.0",
		"publint": "^0.3.0",
		"tsdown": "^0.21.7",
		"tsx": "^4.19.0",
		"typescript": "^5.8.0",
		"vitest": "^3.1.0"
	},
	"packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
